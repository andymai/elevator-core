{
  "name": "elevator-playground",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"scripts/**/*.mjs\" \"*.{json,md,yml}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\" \"scripts/**/*.mjs\" \"*.{json,md,yml}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "knip": "knip",
    "quality": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run knip && pnpm run test",
    "snap": "vite build && vite preview --port 4173 & sleep 2 && node scripts/snap.mjs ; kill %1 2>/dev/null || true"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,html}": [
      "prettier --write"
    ],
    "*.mjs": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.0.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@eslint/js": "^10.0.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "globals": "^17.0.0",
    "knip": "^6.5.0",
    "lint-staged": "^16.0.0",
    "prettier": "^3.8.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.30.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "random-words": "^2.0.1"
  }
}
